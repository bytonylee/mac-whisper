# Build output — ignore everything under build/ except the release DMG,
# which is tracked so it can be shared/downloaded directly from the repo.
/build/*
!/build/MacWhisper.dmg
.build/

# Local environment file — holds the LLM API key (MACWHISPER_LLM_API_KEY).
# Never commit this. See .env.example for the format.
.env

# Logs
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.cursor/
.codex/
*.swp
*.swo
*.iml

# Stale demo gif duplicate — the README uses public/assets/readme/mac-whisper-demo.gif
/mac-whisper-demo.gif

# Coverage / cache
coverage/
.cache/
__pycache__/
*.py[cod]

# Codex imagegen workspace
tmp/

# Bun / Node
node_modules/
bun.lock
bun.lockb
